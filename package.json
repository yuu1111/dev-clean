{
	"name": "dev-clean",
	"version": "1.0.8",
	"description": "Detect and kill lingering dev server processes",
	"type": "module",
	"bin": {
		"dev-clean": "dist/cli.js"
	},
	"files": [
		"dist",
		"README.md",
		"README.ja.md",
		"CLAUDE.md",
		"AGENTS.md"
	],
	"scripts": {
		"build": "bun build.ts",
		"prepare": "bun run build",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write --unsafe .",
		"test": "bun test"
	},
	"keywords": [
		"dev",
		"clean",
		"process",
		"kill",
		"port"
	],
	"author": "yuu1111",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yuu1111/dev-clean.git"
	},
	"engines": {
		"node": ">=18.3.0"
	},
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.10",
		"@yuu1111/biome-config": "^1.0.3",
		"@yuu1111/tsconfig": "^1.0.2",
		"esbuild": "^0.27.4",
		"typescript": "^5.9.3"
	}
}
